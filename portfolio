<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Web Vulnerability Scanner — Live Demo</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
  body{ padding-bottom: 40px; }
  .demo-badge{
    display:inline-block; background:#FFF3CD; color:#664D03; border:1px solid #FFE69C;
    font-size:13px; padding:8px 14px; border-radius:6px; margin-bottom:18px;
  }
  #resultSection{ display:none; }
  .scanning{ opacity:0.6; pointer-events:none; }
</style>
</head>

<body class="bg-light">

<div class="container py-5">

  <h2 class="text-center mb-2">🔍 Web Vulnerability Scanner</h2>
  <p class="text-center text-muted mb-4">by Kavya Sharma</p>

  <div class="text-center">
    <span class="demo-badge">⚠ Interactive demo — results below are simulated for preview purposes. The real scanner runs on Python (Requests + BeautifulSoup) and needs a live backend to perform an actual scan.</span>
  </div>

  <div class="card shadow p-4" id="formCard">
    <label class="form-label">Enter Website URL</label>
    <input type="text" id="urlInput" class="form-control" placeholder="https://example.com">
    <button class="btn btn-primary mt-3 w-100" id="scanBtn">Scan Website</button>
  </div>

  <div id="resultSection" class="mt-4">

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>📊 Summary</h4>
        <p><b>Target:</b> <span id="outTarget"></span></p>
        <p><b>Score:</b> <span id="outScore"></span>/100</p>
        <div class="progress mb-3" style="height:25px;">
          <div class="progress-bar bg-warning" id="scoreBar" style="width:0%;">0%</div>
        </div>
        <p><b>Risk:</b> <span class="badge bg-warning text-dark">MEDIUM</span></p>
      </div>
    </div>

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>🌐 Website Info</h4>
        <p>Status: 200 OK</p>
        <p>Server: nginx</p>
        <p>Content Type: text/html; charset=UTF-8</p>
        <p>HTTPS: Enabled</p>
        <p>Response Time: 0.41 sec</p>
      </div>
    </div>

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>🔒 Security Headers</h4>
        <ul class="mb-0">
          <li>Content-Security-Policy : Missing</li>
          <li>X-Frame-Options : Present</li>
          <li>Strict-Transport-Security : Present</li>
          <li>X-Content-Type-Options : Missing</li>
        </ul>
      </div>
    </div>

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>🤖 Website Files</h4>
        <p>robots.txt: Found</p>
        <p>sitemap.xml: Not found</p>
      </div>
    </div>

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>🔗 Links</h4>
        <p>Total: 27</p>
        <ul class="mb-0">
          <li id="outUrl2"></li>
          <li>/about</li>
          <li>/contact</li>
        </ul>
      </div>
    </div>

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>📁 Admin Pages</h4>
        <ul class="mb-0">
          <li>/admin : 403 Forbidden</li>
          <li>/wp-admin : 404 Not Found</li>
        </ul>
      </div>
    </div>

    <div class="card shadow mb-4">
      <div class="card-body">
        <h4>🍪 Cookies</h4>
        <p>Secure: True</p>
        <p>HttpOnly: True</p>
      </div>
    </div>

    <div class="text-center mt-4">
      <button class="btn btn-primary" id="resetBtn">Scan Another Website</button>
    </div>
  </div>

</div>

<script>
  const scanBtn = document.getElementById('scanBtn');
  const resetBtn = document.getElementById('resetBtn');
  const formCard = document.getElementById('formCard');
  const resultSection = document.getElementById('resultSection');

  scanBtn.addEventListener('click', () => {
    const url = document.getElementById('urlInput').value.trim() || 'https://example.com';
    formCard.classList.add('scanning');
    scanBtn.textContent = 'Scanning...';

    setTimeout(() => {
      document.getElementById('outTarget').textContent = url;
      document.getElementById('outUrl2').textContent = url.replace(/\/$/, '') + '/products';
      const score = 68;
      document.getElementById('outScore').textContent = score;
      const bar = document.getElementById('scoreBar');
      bar.style.width = score + '%';
      bar.textContent = score + '%';

      formCard.classList.remove('scanning');
      scanBtn.textContent = 'Scan Website';
      formCard.style.display = 'none';
      resultSection.style.display = 'block';
      resultSection.scrollIntoView({ behavior: 'smooth' });
    }, 900);
  });

  resetBtn.addEventListener('click', () => {
    resultSection.style.display = 'none';
    formCard.style.display = 'block';
    document.getElementById('urlInput').value = '';
  });
</script>

</body>
</html>
