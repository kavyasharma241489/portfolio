let content = JSON.parse(JSON.stringify(defaultContent));
let editing = false;

document.getElementById('year').textContent = new Date().getFullYear();

function render(){
  document.getElementById('statusLine').textContent = content.status;
  document.getElementById('heroTagline').textContent = content.tagline;
  document.getElementById('aboutText').textContent = content.about;
  document.getElementById('footerName').textContent = content.name;
  document.getElementById('detEmail').textContent = content.contact.email;

  document.getElementById('emailLink').href = 'mailto:' + content.contact.email;
  document.getElementById('githubLink').href = content.contact.github;
  document.getElementById('linkedinLink').href = content.contact.linkedin;

  renderSkills();
  renderCerts();
  renderProjects();
  renderEducation();
  applyEditState();
}

function renderSkills(){
  const grid = document.getElementById('skillsGrid');
  grid.innerHTML = '';
  content.skills.forEach((s, idx) => {
    const chip = document.createElement('div');
    chip.className = 'skill-chip reveal in';
    chip.innerHTML = `
      <span contenteditable="false" data-field="skills.${idx}.name">${s.name}</span>
      <span style="display:flex; align-items:center; gap:6px;">
        <span class="lvl" contenteditable="false" data-field="skills.${idx}.level">${s.level}</span>
        <span class="chip-x edit-only" data-remove-skill="${idx}">×</span>
      </span>`;
    grid.appendChild(chip);
  });
}

function renderCerts(){
  const grid = document.getElementById('certGrid');
  grid.innerHTML = '';
  content.certificates.forEach((c, idx) => {
    const card = document.createElement('div');
    card.className = 'cert-card reveal in';
    card.innerHTML = `
      <button class="mini-btn card-remove edit-only" data-remove-cert="${idx}">remove</button>
      <div class="cert-tag" contenteditable="false" data-field="certificates.${idx}.issuer">${c.issuer}</div>
      <div class="cert-name" contenteditable="false" data-field="certificates.${idx}.name">${c.name}</div>
      <a class="cert-view" href="${c.url}" target="_blank" rel="noopener">View certificate ↗</a>
      <span class="link-edit edit-only" data-edit-cert="${idx}" style="margin-left:8px;">✎ link</span>`;
    grid.appendChild(card);
  });
}

function renderProjects(){
  const list = document.getElementById('projectsList');
  list.innerHTML = '';
  content.projects.forEach((p, idx) => {
    const card = document.createElement('div');
    card.className = 'project-card reveal in';
    card.innerHTML = `
      <button class="mini-btn card-remove edit-only" data-remove-project="${idx}">remove</button>
      <div class="project-head">
        <div class="project-name" contenteditable="false" data-field="projects.${idx}.name">${p.name}</div>
        <div class="status-pill" contenteditable="false" data-field="projects.${idx}.status">${p.status}</div>
      </div>
      <p class="project-desc" contenteditable="false" data-field="projects.${idx}.description">${p.description}</p>
      <div class="scan-results">
        ${p.results.map((r, ri) => `<div><span class="port">[OPEN]</span><span contenteditable="false" data-field="projects.${idx}.results.${ri}">${r}</span></div>`).join('')}
      </div>
      <div class="tech-tags">
        ${p.tags.map((t, ti) => `<span class="tag"><span contenteditable="false" data-field="projects.${idx}.tags.${ti}">${t}</span><span class="tag-x edit-only" data-remove-tag="${idx}.${ti}">×</span></span>`).join('')}
        <button class="mini-btn add edit-only" data-add-tag="${idx}">+ tag</button>
      </div>
      <div class="project-links">
        <a href="${p.githubUrl}" target="_blank" rel="noopener">View on GitHub →</a>
        <span class="link-edit edit-only" data-edit-link="projects.${idx}.githubUrl">✎</span>
        <a href="${p.liveUrl}" target="_blank" rel="noopener">Live Demo →</a>
        <span class="link-edit edit-only" data-edit-link="projects.${idx}.liveUrl">✎</span>
      </div>
    `;
