<script>
/* ---------------- CONTENT ----------------
   Hosting this yourself (Vercel/GitHub Pages)? Keep index.html, photo.jpg,
   resume.pdf and demo.html together in the same folder — the links below
   are relative paths. You can also just edit the values below by hand.
------------------------------------------- */
const defaultContent = {
  name: "Kavya Sharma",
  status: "STATUS: OPEN TO OPPORTUNITIES",
  tagline: "Kavya Sharma — 3rd-year Cybersecurity student (B.Tech CSE & Cyber Security, AITR Indore). I build tools that probe, scan, and break things on purpose, so they don't break for real.",
  about: "Energetic and self-motivated, with a strong interest in software development, problem-solving, and modern technologies. I enjoy security challenges that mix analytical thinking with hands-on coding — currently sharpening that through coursework, NPTEL certifications, and independent projects like my web vulnerability scanner. Outside of code: competitive programming, hackathons, badminton, and music.",
  skills: [
    { name: "Python", level: "core" },
    { name: "C / C++", level: "core" },
    { name: "OOPs & DSA", level: "core" },
    { name: "HTML / CSS", level: "core" },
    { name: "JavaScript", level: "building" },
    { name: "REST APIs", level: "building" },
    { name: "MySQL / DBMS", level: "building" },
    { name: "Git & GitHub", level: "core" },
    { name: "Linux", level: "daily driver" },
    { name: "VS Code", level: "daily driver" },
    { name: "OSINT / Google Dorking", level: "learning" }
  ],
  certificates: [
    {
      name: "Joy of Computing using Python",
      issuer: "NPTEL",
      url: "https://drive.google.com/file/d/1gQRNsjI8RS63w0cDs-SCD8YxZyx9vXch/view?usp=sharing"
    },
    {
      name: "Fundamentals of Object Oriented Programming",
      issuer: "NPTEL",
      url: "https://drive.google.com/file/d/101BckiKxHYJG-SlCmpBU5Gt4ooukH7VJ/view?usp=drivesdk"
    }
  ],
  projects: [
    {
      name: "Web Vulnerability Scanner",
      status: "PYTHON DEVELOPER — MAY–JUN 2026",
      description: "A tool that scans a target website and detects common security vulnerabilities such as SQL injection, XSS, and insecure headers, generating a summary report of the issues found. Built with Requests + BeautifulSoup for crawling, regex-based pattern matching, and multithreading for faster scans.",
      results: ["SQL injection checks", "XSS detection", "insecure security-header audit", "multithreaded crawling"],
      tags: ["Python", "Requests", "BeautifulSoup", "Regex", "Multithreading"],
      githubUrl: "#",
      liveUrl: "demo.html"
    }
  ],
  education: [
    { year: "2024–28", degree: "B.Tech, CSE & Cyber Security", place: "Acropolis Institute of Technology & Research (AITR), Indore — affiliated to RGPV Bhopal · 3rd year, in progress" },
    { year: "12th", degree: "Higher Secondary (MP Board)", place: "Vinayak Public School, Badnagar" },
    { year: "10th", degree: "Secondary (CBSE)", place: "Vinayak Convent School, Dalauda" }
  ],
  contact: {
    email: "kavyasharma0293@gmail.com",
    github: "#",
    linkedin: "#"
  }
};

const STORAGE_KEY = "portfolio-content-v2";
let content = JSON.parse(JSON.stringify(defaultContent));
let editing = false;

document.getElementById('year').textContent = new Date().getFullYear();

function render(){
  document.getElementById('statusLine').textContent = content.status;
  document.getElementById('heroTagline').textContent = content.tagline;
  document.getElementById('aboutText').textContent = content.about;
  document.getElementById('footerName').textContent = content.name;
  document.getElementById('detEmail').textContent = content.contact.email;

  document.getElementById('emailLink').href = 'mailto:' + content.contact.email;
  document.getElementById('githubLink').href = content.contact.github;
  document.getElementById('linkedinLink').href = content.contact.linkedin;

  renderSkills();
  renderCerts();
  renderProjects();
  renderEducation();
  applyEditState();
}

function renderSkills(){
  const grid = document.getElementById('skillsGrid');
  grid.innerHTML = '';
  content.skills.forEach((s, idx) => {
    const chip = document.createElement('div');
    chip.className = 'skill-chip reveal in';
    chip.innerHTML = `
      <span contenteditable="false" data-field="skills.${idx}.name">${s.name}</span>
      <span style="display:flex; align-items:center; gap:6px;">
        <span class="lvl" contenteditable="false" data-field="skills.${idx}.level">${s.level}</span>
        <span class="chip-x edit-only" data-remove-skill="${idx}">×</span>
      </span>`;
    grid.appendChild(chip);
  });
}

function renderCerts(){
  const grid = document.getElementById('certGrid');
  grid.innerHTML = '';
  content.certificates.forEach((c, idx) => {
    const card = document.createElement('div');
    card.className = 'cert-card reveal in';
    card.innerHTML = `
      <button class="mini-btn card-remove edit-only" data-remove-cert="${idx}">remove</button>
      <div class="cert-tag" contenteditable="false" data-field="certificates.${idx}.issuer">${c.issuer}</div>
      <div class="cert-name" contenteditable="false" data-field="certificates.${idx}.name">${c.name}</div>
      <a class="cert-view" href="${c.url}" target="_blank" rel="noopener">View certificate ↗</a>
      <span class="link-edit edit-only" data-edit-cert="${idx}" style="margin-left:8px;">✎ link</span>`;
    grid.appendChild(card);
  });
}

function renderProjects(){
  const list = document.getElementById('projectsList');
  list.innerHTML = '';
  content.projects.forEach((p, idx) => {
    const card = document.createElement('div');
    card.className = 'project-card reveal in';
    card.innerHTML = `
      <button class="mini-btn card-remove edit-only" data-remove-project="${idx}">remove</button>
      <div class="project-head">
        <div class="project-name" contenteditable="false" data-field="projects.${idx}.name">${p.name}</div>
        <div class="status-pill" contenteditable="false" data-field="projects.${idx}.status">${p.status}</div>
      </div>
      <p class="project-desc" contenteditable="false" data-field="projects.${idx}.description">${p.description}</p>
      <div class="scan-results">
        ${p.results.map((r, ri) => `<div><span class="port">[OPEN]</span><span contenteditable="false" data-field="projects.${idx}.results.${ri}">${r}</span></div>`).join('')}
      </div>
      <div class="tech-tags">
        ${p.tags.map((t, ti) => `<span class="tag"><span contenteditable="false" data-field="projects.${idx}.tags.${ti}">${t}</span><span class="tag-x edit-only" data-remove-tag="${idx}.${ti}">×</span></span>`).join('')}
        <button class="mini-btn add edit-only" data-add-tag="${idx}">+ tag</button>
      </div>
      <div class="project-links">
        <a href="${p.githubUrl}" target="_blank" rel="noopener">View on GitHub →</a>
        <span class="link-edit edit-only" data-edit-link="projects.${idx}.githubUrl">✎</span>
        <a href="${p.liveUrl}" target="_blank" rel="noopener">Live Demo →</a>
        <span class="link-edit edit-only" data-edit-link="projects.${idx}.liveUrl">✎</span>
      </div>
    `;
    list.appendChild(card);
  });
}

function renderEducation(){
  const list = document.getElementById('eduList');
  list.innerHTML = '';
  content.education.forEach((e) => {
    const item = document.createElement('div');
    item.className = 'edu-item reveal in';
    item.innerHTML = `
      <div class="edu-year">${e.year}</div>
      <div>
        <div class="edu-degree">${e.degree}</div>
        <div class="edu-place">${e.place}</div>
      </div>`;
    list.appendChild(item);
  });
}

function getPath(obj, path){ return path.split('.').reduce((o,k) => o[k], obj); }
function setPath(obj, path, value){
  const parts = path.split('.');
  const last = parts.pop();
  const target = parts.reduce((o,k) => o[k], obj);
  target[last] = value;
}

function applyEditState(){
  document.body.classList.toggle('editing', editing);
  document.querySelectorAll('[data-field]').forEach(el => el.setAttribute('contenteditable', editing ? 'true' : 'false'));
  document.getElementById('statusLine').setAttribute('contenteditable', editing ? 'true' : 'false');
  document.getElementById('heroTagline').setAttribute('contenteditable', editing ? 'true' : 'false');
  document.getElementById('aboutText').setAttribute('contenteditable', editing ? 'true' : 'false');

  const toolbar = document.getElementById('editToolbar');
  const fab = document.getElementById('editToggle');
  toolbar.classList.toggle('show', editing);
  fab.classList.toggle('on', editing);
  fab.textContent = editing ? '● editing' : '✎ Edit page';
}

function collectEditsIntoContent(){
  content.status = document.getElementById('statusLine').textContent.trim();
  content.tagline = document.getElementById('heroTagline').textContent.trim();
  content.about = document.getElementById('aboutText').textContent.trim();
  document.querySelectorAll('[data-field]').forEach(el => {
    setPath(content, el.getAttribute('data-field'), el.textContent.trim());
  });
}

document.getElementById('editToggle').addEventListener('click', () => {
  editing = !editing;
  if(!editing) collectEditsIntoContent();
  applyEditState();
});
document.getElementById('cancelBtn').addEventListener('click', () => {
  collectEditsIntoContent();
  editing = false;
  applyEditState();
});

document.getElementById('addSkillBtn').addEventListener('click', () => {
  collectEditsIntoContent();
  content.skills.push({ name: "New skill", level: "learning" });
  renderSkills(); applyEditState();
});

document.getElementById('addCertBtn').addEventListener('click', () => {
  collectEditsIntoContent();
  content.certificates.push({ name: "New certificate", issuer: "Issuer", url: "#" });
  renderCerts(); applyEditState();
});

document.getElementById('addProjectBtn').addEventListener('click', () => {
  collectEditsIntoContent();
  content.projects.push({
    name: "New Project", status: "IN PROGRESS",
    description: "Describe what it does and why you built it.",
    results: ["what it checks"], tags: ["Python"],
    githubUrl: "#", liveUrl: "#"
  });
  renderProjects(); applyEditState();
});

document.getElementById('skillsGrid').addEventListener('click', (e) => {
  const rm = e.target.getAttribute('data-remove-skill');
  if(rm !== null){ collectEditsIntoContent(); content.skills.splice(Number(rm),1); renderSkills(); applyEditState(); }
});

document.getElementById('certGrid').addEventListener('click', (e) => {
  const rm = e.target.getAttribute('data-remove-cert');
  if(rm !== null){ collectEditsIntoContent(); content.certificates.splice(Number(rm),1); renderCerts(); applyEditState(); return; }
  const editCert = e.target.getAttribute('data-edit-cert');
  if(editCert !== null){
    collectEditsIntoContent();
    const val = prompt('Certificate link (Drive URL):', content.certificates[Number(editCert)].url);
    if(val !== null){ content.certificates[Number(editCert)].url = val.trim(); renderCerts(); applyEditState(); }
  }
});

document.getElementById('projectsList').addEventListener('click', (e) => {
  const rm = e.target.getAttribute('data-remove-project');
  if(rm !== null){ collectEditsIntoContent(); content.projects.splice(Number(rm),1); renderProjects(); applyEditState(); return; }
  const addTag = e.target.getAttribute('data-add-tag');
  if(addTag !== null){ collectEditsIntoContent(); content.projects[Number(addTag)].tags.push("New tag"); renderProjects(); applyEditState(); return; }
  const rmTag = e.target.getAttribute('data-remove-tag');
  if(rmTag !== null){ collectEditsIntoContent(); const [pi,ti] = rmTag.split('.').map(Number); content.projects[pi].tags.splice(ti,1); renderProjects(); applyEditState(); return; }
  const editLink = e.target.getAttribute('data-edit-link');
  if(editLink !== null){
    collectEditsIntoContent();
    const val = prompt('Enter URL:', getPath(content, editLink));
    if(val !== null){ setPath(content, editLink, val.trim()); renderProjects(); applyEditState(); }
  }
});

document.getElementById('editGithub').addEventListener('click', () => {
  collectEditsIntoContent();
  const val = prompt('GitHub URL:', content.contact.github);
  if(val !== null){ content.contact.github = val.trim(); render(); editing = true; applyEditState(); }
});
document.getElementById('editLinkedin').addEventListener('click', () => {
  collectEditsIntoContent();
  const val = prompt('LinkedIn URL:', content.contact.linkedin);
  if(val !== null){ content.contact.linkedin = val.trim(); render(); editing = true; applyEditState(); }
});

const saveStatus = document.getElementById('saveStatus');
document.getElementById('saveBtn').addEventListener('click', async () => {
  collectEditsIntoContent();
  saveStatus.textContent = 'Saving...';
  try{
    const result = await window.storage.set(STORAGE_KEY, JSON.stringify(content), false);
    saveStatus.textContent = result ? 'Saved ✓' : 'Save failed — try again';
  }catch(err){
    console.error('Storage error:', err);
    saveStatus.textContent = 'Save failed — try again';
  }
  setTimeout(() => { saveStatus.textContent = 'Editing — click highlighted text, or ✎ next to links'; }, 2000);
});

async function loadContent(){
  try{
    const result = await window.storage.get(STORAGE_KEY);
    if(result && result.value) content = JSON.parse(result.value);
  }catch(err){
    content = JSON.parse(JSON.stringify(defaultContent));
  }
  render();
  runTerminal();
  setupReveal();
}

function runTerminal(){
  const lines = [
    { type:'cmd', text:'whoami' },
    { type:'out', text: content.name + ' — Cybersecurity Student, 3rd Year' },
    { type:'cmd', text:'nmap -sV kavya.dev' },
    { type:'out', text:'Starting scan...' },
    { type:'ok',  text:'PORT 80  OPEN   curiosity' },
    { type:'ok',  text:'PORT 443 OPEN   python-scripting' },
    { type:'warn',text:'PORT 22  OPEN   currently-hacking-on-a-scanner' },
    { type:'out', text:'Scan complete. 1 human found, 0 vulnerabilities in her code.' },
  ];
  const termBody = document.getElementById('termBody');
  termBody.innerHTML = '';
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function typeLine(line, container, cb){
    const div = document.createElement('div');
    div.className = 'term-line';
    if(line.type === 'cmd'){
      const prompt = document.createElement('span');
      prompt.className = 'term-prompt';
      prompt.textContent = '$ ';
      div.appendChild(prompt);
    } else if(line.type === 'ok'){ div.classList.add('term-ok'); }
    else if(line.type === 'warn'){ div.classList.add('term-warn'); }
    else { div.classList.add('term-out'); }
    container.appendChild(div);
    if(reduced){ div.textContent = (line.type==='cmd' ? '$ ' : '') + line.text; cb(); return; }
    let i = 0;
    const speed = line.type === 'cmd' ? 38 : 10;
    function step(){
      if(i <= line.text.length){
        div.textContent = (line.type==='cmd' ? '$ ' : '') + line.text.slice(0,i);
        i++; setTimeout(step, speed);
      } else { cb(); }
    }
    step();
  }
  function runSequence(idx){
    if(idx >= lines.length){
      const c = document.createElement('div');
      c.className = 'term-line';
      c.innerHTML = '<span class="term-prompt">$ </span><span class="cursor"></span>';
      termBody.appendChild(c);
      return;
    }
    typeLine(lines[idx], termBody, () => setTimeout(() => runSequence(idx+1), 220));
  }
  runSequence(0);
}

function setupReveal(){
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
}

loadContent();
</script>

